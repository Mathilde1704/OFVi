library(RANN)
# Inventaire terrain limité au quadrat rouge
tab_inv_17 <- data.table(st_drop_geometry(
  tab_inv_sf[countains_inv_grille[[1]], ]
))

# Match seulement les arbres du quadrat rouge avec les arbres LiDAR
tab_nn <- nn2(
  XY_inv_las_130[, c("X_mean", "Y_mean")],
  tab_inv_17[, c("CenterX", "CenterY")],
  k = 1,
  radius = 1
)
#= les arbres terrain du quadrat rouge qui ont un arbre LiDAR à moins de 1 m.
idx_match <- which(tab_nn$nn.dists[, 1] < 1)
#= la table finale des arbres qu’on veut exporter
tab_inv_Quadra17 <- tab_inv_17[idx_match, ]

tab_inv_Quadra17[, dist_laz := tab_nn$nn.dists[idx_match, 1]]
tab_inv_Quadra17[, treeID_laz := XY_inv_las_130$treeID[tab_nn$nn.idx[idx_match, 1]]]
tab_inv_Quadra17[, Z := XY_inv_las_130$Z_mean[tab_nn$nn.idx[idx_match, 1]]]
tab_inv_Quadra17[, N_laz := XY_inv_las_130$N[tab_nn$nn.idx[idx_match, 1]]]

