    ""
  )
  
  writeLAS(
    context_i,
    paste0(
      "G:/MathildeMillan_DD/arbor/extraction_quadrats/20m_20m_15mbuffer/quadrat_17/tree_context_sans_buffer_avec_doublon//",
      tree_inv_id,
      "_treeIDlaz_",
      tree_laz_id,
      suffixe,
      ".laz"
    )
  )
}

